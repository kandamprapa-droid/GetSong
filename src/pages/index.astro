---
import { supabase } from "../lib/supabase";
const { data: videos } = await supabase.from("videos").select("*");
---

<html>
  <head>
    <meta charset="UTF-8">
    <title>คลังวิดีโอของฉัน</title>
    <style>
      body { font-family: sans-serif; padding: 20px; }
      .video-card { border: 1px solid #ccc; padding: 10px; margin-bottom: 10px; border-radius: 8px; }
    </style>
  </head>
  <body>
    <h1>คลังวิดีโอของฉัน</h1>
    
    {videos && videos.length > 0 ? (
      videos.map((video) => (
        <div class="video-card">
          <h2>{video.title}</h2>
          <a href={video.url} target="_blank">ดูวิดีโอคลิกที่นี่</a>
        </div>
      ))
    ) : (
      <p>ยังไม่มีวิดีโอในระบบ</p>
    )}
  </body>
</html>